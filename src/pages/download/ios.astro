---
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getDeltaData } from '../../data/versions';
import { getBreadcrumbSchema } from '../../lib/site';

const deltaData = await getDeltaData();
const latest = deltaData.ios[0];
const older = deltaData.ios.slice(1);

const faqs = [
  {
    q: 'Is Delta Executor safe to use on iOS?',
    a: "Using any third-party script executor goes against Roblox's Terms of Use, and Roblox can ban accounts found using one. We won't claim otherwise. No executor can honestly guarantee permanent, undetectable status.",
  },
  {
    q: 'Why do I need a computer to install this on iPhone?',
    a: "Apple doesn't allow installing apps outside the App Store without a developer certificate, so sideloading tools like AltStore need a computer to sign the app for your device the first time. After that, AltStore can refresh it over Wi-Fi.",
  },
  {
    q: 'Why does the app stop working after a week?',
    a: 'Free Apple developer certificates expire every 7 days, an Apple platform limit, not something specific to this app. Open AltStore on Wi-Fi periodically and it can usually re-sign it automatically.',
  },
  {
    q: 'Why does Delta Executor ask for a key when I open it?',
    a: 'The first time you launch the app, it shows a key entry popup with a link to get a free key. This happens inside the app itself, not on this website, so follow the link in that popup rather than looking for a key page here.',
  },
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Delta Executor for iOS',
    operatingSystem: 'iOS',
    applicationCategory: 'GameApplication',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    softwareVersion: latest.version,
    fileSize: latest.fileSize,
    description: 'Delta Executor is a third-party Roblox script executor for iOS, sideloaded via AltStore, no jailbreak required.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  getBreadcrumbSchema(Astro, [
    { name: 'Home', path: '/' },
    { name: 'Download', path: '/download' },
    { name: 'iOS', path: '/download/ios' },
  ]),
];
---

<Layout
  title={`Download Delta Executor v${latest.version} for iOS | Free Roblox Script Executor`}
  description={`Download Delta Executor v${latest.version} for iOS (${latest.fileSize}). Sideloaded via AltStore, no jailbreak required. Updated ${latest.released}.`}
  canonicalPath="/download/ios"
>
  <Fragment slot="head">
    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </Fragment>

  <section class="bg-bg px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <nav class="text-sm text-text-muted">
        <a href="/" class="hover:text-primary-light">Home</a> /
        <a href="/download" class="hover:text-primary-light">Download</a> /
        <span class="text-text">iOS</span>
      </nav>

      <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Delta Executor for iOS</h1>
      <p class="mt-2 text-text-muted">Sideloaded via AltStore, no jailbreak required.</p>

      <div class="mt-8 rounded-2xl border border-primary/30 card p-7">
        <div class="flex flex-wrap items-center gap-4 text-base text-text-muted">
          <span class="flex items-center gap-1.5"><Icon name="tabler:git-branch" class="h-4 w-4" />v{latest.version}</span>
          <span class="flex items-center gap-1.5"><Icon name="tabler:file-zip" class="h-4 w-4" />{latest.fileSize}</span>
          <span class="flex items-center gap-1.5"><Icon name="tabler:calendar" class="h-4 w-4" />{latest.released}</span>
        </div>
        {latest.downloadUrl ? (
          <a href={latest.downloadUrl} class="btn-primary mt-5 inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-base font-semibold text-white">
            <Icon name="tabler:download" class="h-5 w-5" />Download v{latest.version} for iOS
          </a>
        ) : (
          <p class="mt-5 text-base text-text-muted">Download link not published yet for this version.</p>
        )}
        <p class="mt-4 text-sm text-text-muted">
          On Android instead?
          <a href="/download/android" class="font-medium text-primary-light underline-offset-4 transition-colors hover:text-accent hover:underline">Get the APK &rarr;</a>
        </p>
      </div>

      <section class="mt-10">
        <h2 class="text-2xl font-bold text-text">Requirements</h2>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {[
            ['iOS version', '15.0+'],
            ['Free storage', '300 MB+'],
            ['Jailbreak required', 'No'],
            ['Computer needed', 'Once'],
          ].map(([label, value]) => (
            <div class="card rounded-xl border border-primary/10 p-4 text-center">
              <p class="text-sm uppercase tracking-wider text-text-muted">{label}</p>
              <p class="mt-1 text-base font-semibold text-text">{value}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mt-10">
        <h2 class="text-2xl font-bold text-text">How to Install with AltStore</h2>
        <ol class="mt-4 list-decimal space-y-2.5 pl-5 text-base text-text-muted">
          <li>Download the IPA file from the button above.</li>
          <li>Install AltServer on a Windows or Mac computer (one-time setup, free from altstore.io).</li>
          <li>Connect your iPhone or iPad to that computer and open AltStore on the device.</li>
          <li>Select the downloaded IPA file in AltStore to install it.</li>
          <li>Trust the developer certificate: Settings, then General, then VPN &amp; Device Management.</li>
          <li>Open Delta Executor, follow the in-app key popup to get a free key.</li>
          <li>Keep AltServer running occasionally on Wi-Fi so AltStore can refresh the app before its 7-day certificate expires.</li>
        </ol>
      </section>

      <section class="mt-10 rounded-2xl border border-emerald-500/25 bg-emerald-500/5 p-7">
        <h2 class="flex items-center gap-2 text-2xl font-bold text-text">
          <Icon name="tabler:circle-check" class="h-6 w-6 text-emerald-400" />Confirm it's actually working
        </h2>
        <div class="mt-3 space-y-3 text-base leading-relaxed text-text-muted">
          <p>After trusting the certificate and opening Delta, the app icon should launch without an "Untrusted Developer" warning. Once inside a Roblox game, the floating Delta icon appearing on screen is the real confirmation, tap it to open the script hub and try running a script.</p>
          <p>iOS sideloaded apps are tied to a 7-day certificate by design, an Apple platform limit, not something specific to this app. If it suddenly won't open partway through the week, that's almost always the certificate expiring, not a bug.</p>
        </div>
      </section>

      <section class="mt-10">
        <h2 class="text-2xl font-bold text-text">Installation Troubleshooting</h2>
        <p class="mt-2 text-base text-text-muted">iOS sideloading has more moving parts than Android, most issues trace back to certificate trust or AltServer's connection.</p>
        <div class="card mt-4 overflow-hidden rounded-2xl">
          <table class="w-full text-left text-base">
            <thead>
              <tr class="border-b border-primary/20 bg-bg-card">
                <th class="px-5 py-3 text-sm font-semibold uppercase tracking-wide text-text-muted">What you're seeing</th>
                <th class="px-5 py-3 text-sm font-semibold uppercase tracking-wide text-text-muted">What to do</th>
              </tr>
            </thead>
            <tbody>
              {[
                ['"Untrusted Developer" on first open', 'Go to Settings, then General, then VPN & Device Management, and trust the developer profile listed there.'],
                ['App greyed out / "Unable to Verify App"', 'Your 7-day certificate has expired. Open AltStore on your device while connected to the same Wi-Fi as AltServer to refresh it.'],
                ['AltStore can\u2019t find AltServer', 'Make sure AltServer is running on your computer and both devices are on the same Wi-Fi network, not separate networks or mobile data.'],
                ['Install fails partway through', 'Reconnect the USB cable (first install only) or retry over Wi-Fi once AltServer shows your device as connected.'],
                ['App disappeared from the home screen', 'This usually means the certificate was revoked rather than expired. Reinstall the IPA fresh through AltStore.'],
                ['Stuck on the key popup', "Tap the link inside the popup itself, there's no separate key page on this website to search for."],
              ].map((row) => (
                <tr class="border-b border-primary/10 last:border-0">
                  <td class="px-5 py-3 font-medium text-text">{row[0]}</td>
                  <td class="px-5 py-3 text-text-muted">{row[1]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      {older.length > 0 && (
        <section class="mt-10">
          <h2 class="text-2xl font-bold text-text">Previous Versions</h2>
          <div class="mt-4 space-y-2.5">
            {older.map((v) => (
              <div class="card flex items-center justify-between rounded-xl border border-primary/10 p-4 text-base">
                <div>
                  <span class="font-semibold text-text">v{v.version}</span>
                  <span class="ml-3 text-text-muted">{v.fileSize} &middot; {v.released}</span>
                </div>
                {v.downloadUrl ? (
                  <a href={v.downloadUrl} class="rounded-lg border border-primary/40 px-4 py-2 text-sm font-medium transition-colors hover:border-accent">Download</a>
                ) : (
                  <span class="text-sm text-text-muted">Unavailable</span>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="mt-10">
        <h2 class="text-2xl font-bold text-text">Frequently Asked Questions</h2>
        <div class="mt-4 space-y-3">
          {faqs.map((f) => (
            <details class="group card rounded-xl border border-primary/10 p-5">
              <summary class="flex cursor-pointer list-none items-center justify-between text-base font-semibold text-text marker:content-none">
                {f.q}
                <Icon name="tabler:chevron-down" class="h-5 w-5 shrink-0 text-accent transition-transform duration-300 group-open:rotate-180" />
              </summary>
              <p class="mt-3 text-base leading-relaxed text-text-muted">{f.a}</p>
            </details>
          ))}
        </div>
      </section>
    </div>
  </section>
</Layout>
