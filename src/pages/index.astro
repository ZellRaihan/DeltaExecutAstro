              {f.q}
              <Icon name="tabler:chevron-down" class="h-5 w-5 shrink-0 text-accent transition-transform duration-300 group-open:rotate-180" />
            </summary>
            <p class="mt-3 text-base leading-relaxed text-text-muted">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>
