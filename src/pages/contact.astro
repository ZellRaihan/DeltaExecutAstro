---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import { getBreadcrumbSchema } from '../lib/site';

const discordUrl = 'https://discord.com/invite/deltax';
const supportEmail = 'support@deltaexecut.net';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Delta Executor',
    description: 'Contact information and support options for Delta Executor users. Get help with installation, troubleshooting, and other questions about our Roblox exploit software.',
    url: 'https://deltaexecut.net/contact',
    mainEntity: {
      '@type': 'Organization',
      name: 'Delta Executor',
      email: supportEmail,
      url: 'https://deltaexecut.net',
      logo: 'https://deltaexecut.net/assets/Delta-Executor-Icon.webp',
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'customer support',
          email: supportEmail,
          url: 'https://deltaexecut.net/contact',
          availableLanguage: 'English',
        },
        {
          '@type': 'ContactPoint',
          contactType: 'technical support',
          url: discordUrl,
          availableLanguage: 'English',
        },
      ],
    },
  },
  getBreadcrumbSchema(Astro, [
    { name: 'Home', path: '/' },
    { name: 'Contact Us', path: '/contact' },
  ]),
];
---

<Layout
  title="Contact Us - Delta Executor | Support & Help"
  description="Need help with Delta Executor? Contact our support team for assistance with the #1 free Roblox exploit. Get answers to your questions and technical support."
  canonicalPath="/contact"
>
  <Fragment slot="head">
    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </Fragment>

  <section class="bg-bg px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-3xl font-bold sm:text-4xl">Contact Us</h1>

      <!--
        Note: all three cards below previously linked to "#", a dead link,
        the same pattern flagged at the start of this project. Since there's
        one real support channel (Discord), all three now point to it
        rather than three separate unbuilt destinations.
      -->
      <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-lg border border-primary/10 card p-6 text-center">
          <Icon name="tabler:headset" class="inline h-4 w-4 text-2xl" />
          <h3 class="mt-2 font-semibold">Support</h3>
          <p class="mt-1.5 text-sm text-text-muted">Need help with installation, key system, or troubleshooting? Reach our support team on Discord.</p>
          <a href={discordUrl} class="mt-3 inline-block rounded-lg border border-primary/40 px-4 py-2 text-sm hover:border-accent">
            <Icon name="tabler:brand-discord" class="inline h-4 w-4 mr-1.5" />Discord Support
          </a>
        </div>

        <div class="rounded-lg border border-primary/10 card p-6 text-center">
          <Icon name="tabler:bug" class="inline h-4 w-4 text-2xl" />
          <h3 class="mt-2 font-semibold">Bug Reports</h3>
          <p class="mt-1.5 text-sm text-text-muted">Found a bug or issue? Let us know on Discord so we can fix it in our next update.</p>
          <a href={discordUrl} class="mt-3 inline-block rounded-lg border border-primary/40 px-4 py-2 text-sm hover:border-accent">
            <Icon name="tabler:alert-circle" class="inline h-4 w-4 mr-1.5" />Report Bug
          </a>
        </div>

        <div class="rounded-lg border border-primary/10 card p-6 text-center">
          <Icon name="tabler:bulb" class="inline h-4 w-4 text-2xl" />
          <h3 class="mt-2 font-semibold">Feature Requests</h3>
          <p class="mt-1.5 text-sm text-text-muted">Have an idea to make Delta Executor better? Share it with us on Discord.</p>
          <a href={discordUrl} class="mt-3 inline-block rounded-lg border border-primary/40 px-4 py-2 text-sm hover:border-accent">
            <Icon name="tabler:circle-plus" class="inline h-4 w-4 mr-1.5" />Suggest Feature
          </a>
        </div>
      </div>

      <!--
        Note: the original contact form here faked a successful submission
        (preventDefault, a fake delay, a fake "we'll get back to you" alert)
        with no real backend, no email was ever actually sent. Per explicit
        instruction, replaced with the two real contact methods that
        actually reach someone: Discord and the real support email already
        named in this page's own schema.
      -->
      <section class="mt-10 rounded-lg border border-primary/10 card p-8">
        <h2 class="text-xl font-bold">Get in Touch</h2>
        <p class="mt-2 text-sm text-text">The fastest way to reach us is Discord, where the team and community are active. For anything else, email works too.</p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a href={discordUrl} class="flex-1 rounded-lg bg-primary px-5 py-3 text-center text-sm font-semibold text-white hover:bg-primary-dark">
            <Icon name="tabler:brand-discord" class="inline h-4 w-4 mr-2" />Join Discord
          </a>
          <a href={`mailto:${supportEmail}`} class="flex-1 rounded-lg border border-primary/40 px-5 py-3 text-center text-sm font-semibold hover:border-accent">
            <Icon name="tabler:mail" class="inline h-4 w-4 mr-2" />{supportEmail}
          </a>
        </div>
      </section>

      <section class="mt-10">
        <h2 class="text-xl font-bold">Frequently Asked Questions</h2>
        <div class="mt-4 space-y-3">
          <details class="group rounded-lg border border-primary/10 card p-4">
            <summary class="flex cursor-pointer list-none items-center justify-between font-medium marker:content-none">
              Is Delta Executor safe to use?
              <Icon name="tabler:chevron-down" class="inline h-4 w-4 " />
            </summary>
            <p class="mt-3 text-sm text-text">Delta Executor is generally safe to download and run when it comes from our official website, we don't knowingly include malware or unwanted software. Be cautious of fake versions from unofficial sources, which may contain harmful software. Separately, using any executor still carries a real ban risk from Roblox, that's not something the download source changes.</p>
          </details>
          <details class="group rounded-lg border border-primary/10 card p-4">
            <summary class="flex cursor-pointer list-none items-center justify-between font-medium marker:content-none">
              Why do I need to complete the key system?
              <Icon name="tabler:chevron-down" class="inline h-4 w-4 " />
            </summary>
            <p class="mt-3 text-sm text-text">The key system helps us maintain our servers and continue providing Delta Executor for free. It also helps prevent abuse and ensures only legitimate users can access our service. The process only takes a minute and the key is valid for 24 hours.</p>
          </details>
          <details class="group rounded-lg border border-primary/10 card p-4">
            <summary class="flex cursor-pointer list-none items-center justify-between font-medium marker:content-none">
              How often is Delta Executor updated?
              <Icon name="tabler:chevron-down" class="inline h-4 w-4 " />
            </summary>
            <p class="mt-3 text-sm text-text">We aim to update Delta Executor within hours after Roblox updates, to keep it working against current detection methods. You can check our Discord server for the most up-to-date information.</p>
          </details>
        </div>
        <div class="mt-5 text-center">
          <a href="/#faq-section" class="text-sm text-primary-light hover:text-primary-light">View all FAQs &rarr;</a>
        </div>
      </section>
    </div>
  </section>
</Layout>
