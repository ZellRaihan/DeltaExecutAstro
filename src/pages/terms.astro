---
import Layout from '../layouts/Layout.astro';
import { getBreadcrumbSchema } from '../lib/site';

const lastUpdated = 'March 15, 2025';

const sections = [
  ['1. Acceptance of Terms', 'By downloading, installing, or using Delta Executor ("the Software"), you agree to be bound by these Terms and Conditions. If you do not agree to these terms, please do not download, install, or use the Software.'],
  ['2. License Grant', 'Subject to these Terms, we grant you a limited, non-exclusive, non-transferable, revocable license to use the Software for personal, non-commercial purposes. This license does not include the right to copy, modify, distribute, sell, lease, sublicense, or transfer the Software or any portion thereof.'],
];

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Terms and Conditions',
    description: "Delta Executor's terms and conditions outlining the rules and guidelines for using our Roblox exploit software.",
    inLanguage: 'en-US',
    datePublished: '2023-01-01',
    dateModified: '2025-03-15',
    publisher: {
      '@type': 'Organization',
      name: 'Delta Executor',
      logo: 'https://deltaexecut.net/assets/Delta-Executor-Icon.webp',
    },
    mainEntity: {
      '@type': 'Article',
      headline: 'Delta Executor Terms & Conditions',
      author: { '@type': 'Organization', name: 'Delta Executor Team' },
      publisher: {
        '@type': 'Organization',
        name: 'Delta Executor',
        logo: { '@type': 'ImageObject', url: 'https://deltaexecut.net/assets/Delta-Executor-Icon.webp' },
      },
      datePublished: '2023-01-01',
      dateModified: '2025-03-15',
    },
  },
  getBreadcrumbSchema(Astro, [
    { name: 'Home', path: '/' },
    { name: 'Terms & Conditions', path: '/terms' },
  ]),
];
---

<Layout
  title="Terms & Conditions - Delta Executor | Usage Agreement"
  description="Read Delta Executor's terms and conditions covering license, user conduct, the key system, liability, and your rights as a user."
  canonicalPath="/terms"
>
  <Fragment slot="head">
    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </Fragment>

  <section class="bg-bg px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-3xl font-bold sm:text-4xl">Terms &amp; Conditions</h1>

      <div class="mt-8 space-y-8 text-sm text-text">
        <div>
          <h2 class="text-lg font-semibold text-text">1. Acceptance of Terms</h2>
          <p class="mt-2">By downloading, installing, or using Delta Executor ("the Software"), you agree to be bound by these Terms and Conditions. If you do not agree to these terms, please do not download, install, or use the Software.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">2. License Grant</h2>
          <p class="mt-2">Subject to these Terms, we grant you a limited, non-exclusive, non-transferable, revocable license to use the Software for personal, non-commercial purposes. This license does not include the right to copy, modify, distribute, sell, lease, sublicense, or transfer the Software or any portion thereof.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">3. User Conduct</h2>
          <p class="mt-2">You agree not to use the Software to:</p>
          <ul class="mt-2 list-disc space-y-1.5 pl-5">
            <li>Violate any applicable laws or regulations</li>
            <li>Infringe upon the rights of others</li>
            <li>Distribute malware, viruses, or other harmful code</li>
            <li>Attempt to gain unauthorized access to any service, account, or network</li>
            <li>Interfere with or disrupt the integrity or performance of the Software</li>
            <li>Engage in any activity that could harm minors</li>
            <li>Sell, resell, or commercially exploit the Software</li>
          </ul>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">4. Key System</h2>
          <p class="mt-2">The Software utilizes a key system that requires users to complete certain steps to obtain a key for full functionality. You agree not to bypass, automate, or otherwise circumvent this key system. Keys are valid for 24 hours and are for personal use only. Sharing, selling, or distributing keys is prohibited.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">5. Intellectual Property</h2>
          <p class="mt-2">The Software, including all content, features, and functionality, is owned by us and is protected by copyright, trademark, and other intellectual property laws. You may not use our trademarks, logos, or other proprietary information without our prior written consent.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">6. Third-Party Content</h2>
          <p class="mt-2">The Software may allow you to access third-party content, websites, or services. We do not endorse, control, or assume responsibility for any third-party content, and you access such content at your own risk.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">7. Disclaimer of Warranties</h2>
          <p class="mt-2">THE SOFTWARE IS PROVIDED "AS IS" AND "AS AVAILABLE" WITHOUT WARRANTIES OF ANY KIND, EITHER EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO IMPLIED WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE, AND NON-INFRINGEMENT.</p>
          <p class="mt-2">WE DO NOT WARRANT THAT THE SOFTWARE WILL FUNCTION UNINTERRUPTED, SECURE, OR AVAILABLE AT ANY PARTICULAR TIME OR LOCATION; THAT ANY ERRORS OR DEFECTS WILL BE CORRECTED; OR THAT THE SOFTWARE IS FREE OF VIRUSES OR OTHER HARMFUL COMPONENTS.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">8. Limitation of Liability</h2>
          <p class="mt-2">IN NO EVENT SHALL WE BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES, INCLUDING WITHOUT LIMITATION, LOSS OF PROFITS, DATA, USE, GOODWILL, OR OTHER INTANGIBLE LOSSES, RESULTING FROM YOUR ACCESS TO OR USE OF OR INABILITY TO ACCESS OR USE THE SOFTWARE.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">9. Indemnification</h2>
          <p class="mt-2">You agree to defend, indemnify, and hold us harmless from and against any claims, liabilities, damages, losses, and expenses, including without limitation reasonable attorney fees and costs, arising out of or in any way connected with your access to or use of the Software or your violation of these Terms.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">10. Termination</h2>
          <p class="mt-2">We may terminate or suspend your access to the Software immediately, without prior notice or liability, for any reason whatsoever, including without limitation if you breach these Terms. Upon termination, your right to use the Software will immediately cease.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">11. Governing Law</h2>
          <p class="mt-2">These Terms shall be governed by and construed in accordance with the laws of the jurisdiction in which we operate, without regard to its conflict of law provisions.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">12. Changes to Terms</h2>
          <p class="mt-2">We reserve the right, at our sole discretion, to modify or replace these Terms at any time. If a revision is material, we will try to provide at least 30 days' notice prior to any new terms taking effect. What constitutes a material change will be determined at our sole discretion.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-text">13. Contact Us</h2>
          <p class="mt-2">If you have any questions about these Terms, please contact us at legal@deltaexecut.net.</p>
        </div>

        <p class="border-t border-primary/10 pt-4 text-sm text-text-muted">Last updated: {lastUpdated}</p>
      </div>
    </div>
  </section>
</Layout>
