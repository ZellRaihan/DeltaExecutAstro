---
import { Icon } from 'astro-icon/components';

const currentYear = new Date().getFullYear();

const socialLinks = [
  { label: 'Discord', href: 'https://discord.com/invite/deltax', icon: 'simple-icons:discord' },
  { label: 'Telegram', href: 'https://t.me/deltadyn', icon: 'simple-icons:telegram' },
];

const columns = [
  {
    title: 'Navigation',
    icon: 'tabler:compass',
    links: [
      { label: 'Home', href: '/' },
      { label: 'Download', href: '/#download' },
      { label: 'Features', href: '/#features-section' },
      { label: 'Key System', href: '/#key-system-section' },
    ],
  },
  {
    title: 'Support',
    icon: 'tabler:headset',
    links: [
      { label: 'About Us', href: '/about' },
      { label: 'Contact', href: '/contact' },
      { label: 'FAQ', href: '/#faq-section' },
      { label: 'Troubleshooting', href: '/#troubleshooting-section' },
    ],
  },
  {
    title: 'Legal',
    icon: 'tabler:shield-check',
    links: [
      { label: 'Terms & Conditions', href: '/terms' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Disclaimer', href: '/disclaimer' },
    ],
  },
];
---

<footer class="relative border-t border-primary/20 bg-gradient-to-b from-bg-card/30 to-bg">
  <div class="mx-auto max-w-6xl px-6 pt-16 pb-10">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-3">
          <img src="/assets/Delta-Executor-Icon.webp" alt="Delta Executor Logo" class="h-11 w-11" width="44" height="44" />
          <span class="text-xl font-semibold text-text">Delta Executor</span>
        </div>
        <p class="mt-4 max-w-xs text-base leading-relaxed text-text-muted">Change Your Roblox Experience With Delta Executor</p>

        <div class="mt-6">
          <h3 class="flex items-center gap-1.5 text-sm font-semibold uppercase tracking-wider text-text">
            <Icon name="tabler:users" class="h-4 w-4 text-accent" />Connect With Us
          </h3>
          <div class="mt-3 flex gap-2.5">
            {socialLinks.map((s) => (
              <a
                href={s.href}
                aria-label={s.label}
                class="card flex h-11 w-11 items-center justify-center rounded-full text-text-muted transition-all hover:-translate-y-0.5 hover:text-accent"
              >
                <Icon name={s.icon} class="h-5 w-5" />
              </a>
            ))}
          </div>
        </div>
      </div>

      {columns.map((col) => (
        <div>
          <h3 class="flex items-center gap-1.5 text-sm font-semibold uppercase tracking-wider text-text">
            <Icon name={col.icon} class="h-4 w-4 text-accent" />{col.title}
          </h3>
          <ul class="mt-4 space-y-2.5 text-base">
            {col.links.map((link) => (
              <li>
                <a href={link.href} class="group inline-flex items-center gap-1.5 text-text-muted transition-colors hover:text-accent">
                  <span class="h-1 w-1 rounded-full bg-text-muted/40 transition-colors group-hover:bg-accent"></span>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center gap-3 border-t border-primary/10 pt-8 text-center sm:flex-row sm:justify-between sm:text-left">
      <p class="text-sm text-text-muted">
        &copy; {currentYear} <a href="/" class="font-medium text-text transition-colors hover:text-accent">Delta Executor</a>. All rights reserved.
      </p>
      <p class="flex items-center gap-1.5 text-sm text-text-muted">
        <Icon name="tabler:info-circle" class="h-4 w-4" />Not affiliated with Roblox Corporation.
      </p>
    </div>
  </div>
</footer>
